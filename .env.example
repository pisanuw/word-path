# Copy this file to .env.local (git-ignored) for local development, and set
# the same two values as environment variables in the Netlify dashboard
# (Site settings -> Environment variables) for production.
#
# Both come from your Supabase project: Project Settings -> API.
# Leaderboard is optional -- the game is fully playable without these,
# scores just won't be saved or shown.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
